[application]
name = "Hemion"
default_platform = "desktop"
tailwind_input = "public/tailwind.css"
tailwind_output = "assets/tailwind.css"

[web.app]
title = "Hemion"
base_path = "/"

[web.watcher]
port = 8181
watch_path = ["src", "public"]

[web.resource]

[web.resource.dev]
style = ["assets/tailwind.css"]

[web.resource.build]
style = ["assets/tailwind.css"]

[wasm]
opt-level = 2
